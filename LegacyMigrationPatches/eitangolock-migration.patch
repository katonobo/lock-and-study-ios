diff --git a/EitangoLock/Core/Migration/LockAndStudyLegacyMigrationAdapter.swift b/EitangoLock/Core/Migration/LockAndStudyLegacyMigrationAdapter.swift
new file mode 100644
index 0000000..17c8c47
--- /dev/null
+++ b/EitangoLock/Core/Migration/LockAndStudyLegacyMigrationAdapter.swift
@@ -0,0 +1,54 @@
+import CryptoKit
+import StoreKit
+import SwiftUI
+
+struct EitangoLockLegacyMigrationView: View {
+  let dataStore: LearningDataStore
+
+  var body: some View {
+    LegacyMigrationView {
+      let writer = try LegacyMigrationWriter()
+      var written = 0
+      for await result in StoreKit.Transaction.currentEntitlements {
+        guard case .verified(let transaction) = result,
+              let destination = Self.destination(for: transaction.productID) else { continue }
+        try await writer.appendVerifiedTransaction(
+          transaction,
+          sourceBundleID: "com.ameneko.eitangolock",
+          destinationPackID: destination
+        )
+        written += 1
+      }
+      let progress = try await dataStore.allProgress()
+      let events = progress.values.map { value in
+        LegacyProgressEvent(
+          id: Self.stableID(itemID: value.itemID),
+          sourceBundleID: "com.ameneko.eitangolock",
+          sourceContentVersion: "mvp-3000-ja-v4.0.0",
+          packID: "english3000.v1",
+          itemID: value.itemID,
+          answeredAt: value.lastAnsweredAt,
+          correctCount: value.totalCorrectCount,
+          incorrectCount: value.totalIncorrectCount,
+          dueAt: value.dueAt
+        )
+      }
+      try await writer.writeProgress(sourceBundleID: "com.ameneko.eitangolock", events: events)
+      return written + events.count
+    }
+  }
+
+  private static func destination(for productID: String) -> String?? {
+    switch productID {
+    case "com.ameneko.eitangolock.premium.lifetime": return .some("english3000.v1")
+    case "com.ameneko.eitangolock.premium.monthly", "com.ameneko.eitangolock.premium.yearly": return .some(nil)
+    default: return nil
+    }
+  }
+
+  private static func stableID(itemID: String) -> UUID {
+    let bytes = Array(SHA256.hash(data: Data("com.ameneko.eitangolock|\(itemID)".utf8)))
+    return UUID(uuid: (bytes[0], bytes[1], bytes[2], bytes[3], bytes[4], bytes[5], bytes[6], bytes[7],
+                       bytes[8], bytes[9], bytes[10], bytes[11], bytes[12], bytes[13], bytes[14], bytes[15]))
+  }
+}
