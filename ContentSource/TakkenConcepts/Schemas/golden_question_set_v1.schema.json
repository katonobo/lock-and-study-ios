{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://katonobo.com/schemas/lock-and-study/takken-golden-question-set-v1.json",
  "title": "Lock and Study Takken Golden Question Set v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "packID",
    "goldenQuestionIDs",
    "conceptMappings",
    "distinctConceptCount"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packID": { "const": "takken2026.v1" },
    "goldenQuestionIDs": {
      "type": "array",
      "minItems": 100,
      "maxItems": 100,
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "conceptMappings": {
      "type": "array",
      "minItems": 100,
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["questionID", "conceptID", "mappingStatus"],
        "properties": {
          "questionID": { "type": "string" },
          "conceptID": { "type": "string", "pattern": "^takken\\." },
          "mappingStatus": { "enum": ["ai_draft", "human_reviewed"] }
        },
        "additionalProperties": false
      }
    },
    "distinctConceptCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    }
  },
  "additionalProperties": true
}
