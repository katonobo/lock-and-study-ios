{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://katonobo.com/schemas/lock-and-study/takken-legacy-inventory-v1.json",
  "title": "Lock and Study Takken Legacy Inventory v1 / workflow v18",
  "type": "object",
  "required": [
    "schemaVersion",
    "packID",
    "status",
    "expectedLegacyQuestionCount",
    "sourceFiles",
    "items"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packID": { "const": "takken2026.v1" },
    "status": { "enum": ["ai_draft", "reviewed_mapping"] },
    "expectedLegacyQuestionCount": { "const": 1000 },
    "items": {
      "type": "array",
      "minItems": 1000,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "required": [
          "legacyQuestionID",
          "sourceFile",
          "mappedConceptID",
          "disposition",
          "reason",
          "requiresLegalUpdate",
          "requiresSourceResearch",
          "questionDigest",
          "mappingConfidence",
          "status"
        ],
        "properties": {
          "legacyQuestionID": { "type": "string", "minLength": 1 },
          "mappedConceptID": { "type": "string", "pattern": "^takken\\." },
          "disposition": {
            "enum": [
              "base_variant_candidate",
              "additional_variant_candidate",
              "new_concept_candidate",
              "duplicate",
              "outdated",
              "low_value_retire",
              "requires_legal_research",
              "integrated_case_material"
            ]
          },
          "status": { "enum": ["ai_draft", "reviewed_mapping"] },
          "mappingConfidence": {
            "enum": [
              "ai_clustered_requires_human_review",
              "human_reviewed_concept_boundary"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
