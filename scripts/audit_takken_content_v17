#!/usr/bin/env python3
"""One-command v17 audit, including current Release protection."""
import json
import sys

sys.dont_write_bytecode = True

from takken_concepts import audit_snapshot


snapshot, errors = audit_snapshot()
print(json.dumps(snapshot, ensure_ascii=False, indent=2))
if errors:
    for error in errors:
        print(f"ERROR: {error}")
    raise SystemExit(1)
print("Takken v17 concept, inventory, Golden draft, and Release protection audit passed.")
