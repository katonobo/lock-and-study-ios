#!/usr/bin/env python3
"""Export a deterministic v18 concept-review batch without overwriting reviewer work."""
import argparse
import sys
from pathlib import Path

sys.dont_write_bytecode = True

from takken_concept_workflow import DEFAULT_BATCH_SIZE, export_review_batch
from takken_concepts import MASTER_PATH, REVIEW_BATCH_ROOT, ROOT


parser = argparse.ArgumentParser()
parser.add_argument("batch", type=int)
parser.add_argument("--concept-master", type=Path, default=MASTER_PATH)
parser.add_argument("--output-directory", type=Path, default=REVIEW_BATCH_ROOT)
parser.add_argument("--batch-size", type=int, default=DEFAULT_BATCH_SIZE)
arguments = parser.parse_args()

source = (
    arguments.concept_master
    if arguments.concept_master.is_absolute()
    else ROOT / arguments.concept_master
)
output_root = (
    arguments.output_directory
    if arguments.output_directory.is_absolute()
    else ROOT / arguments.output_directory
)
try:
    output = export_review_batch(
        arguments.batch,
        source_master_path=source,
        output_root=output_root,
        batch_size=arguments.batch_size,
    )
except (FileExistsError, ValueError) as error:
    print(f"ERROR: {error}")
    raise SystemExit(1)
print(f"Exported concept review batch: {output}")
