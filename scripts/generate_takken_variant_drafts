#!/usr/bin/env python3
"""Generate Golden variants; default requires reviewed concepts, draft override stays AI-only."""
import sys

sys.dont_write_bytecode = True

from takken_concepts import (
    VARIANTS_PATH,
    build_concept_assets,
    load_json,
    write_json,
)


allow_draft = sys.argv[1:] == ["--allow-draft-authoring"]
if sys.argv[1:] and not allow_draft:
    print("usage: ./scripts/generate_takken_variant_drafts [--allow-draft-authoring]")
    raise SystemExit(2)
assets = build_concept_assets()
master = assets["master"]
if not allow_draft and any(
    value.get("reviewStatus") not in {"reviewed", "release"}
    for value in master["concepts"]
):
    print("refusing variant generation: concept master is not fully human reviewed")
    raise SystemExit(1)
write_json(VARIANTS_PATH, assets["variants"])
print(
    f"Generated {len(assets['variants']['variants'])} AI-draft variants: "
    f"{VARIANTS_PATH}"
)
