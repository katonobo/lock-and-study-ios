#!/usr/bin/env python3
"""Validate reviewed variant documents against an explicit v18 full-pack plan."""
import argparse
import sys
from pathlib import Path

sys.dont_write_bytecode = True

from takken_concepts import (
    INVENTORY_PATH,
    MASTER_PATH,
    ROOT,
    full_pack_candidate_errors,
    load_json,
)


parser = argparse.ArgumentParser()
parser.add_argument("variants", nargs="+", type=Path)
parser.add_argument("--concept-master", type=Path, default=MASTER_PATH)
parser.add_argument("--inventory", type=Path, default=INVENTORY_PATH)
arguments = parser.parse_args()


def absolute(path: Path) -> Path:
    return path if path.is_absolute() else ROOT / path


variants = []
for value in arguments.variants:
    path = absolute(value).resolve()
    document = load_json(path)
    variants.extend(document.get("variants") or document)
master = load_json(absolute(arguments.concept_master))
inventory = load_json(absolute(arguments.inventory))
errors = full_pack_candidate_errors(variants, master, inventory)
if errors:
    for error in errors[:50]:
        print(f"ERROR: {error}")
    if len(errors) > 50:
        print(f"ERROR: ... {len(errors) - 50} additional validation error(s) omitted")
    raise SystemExit(1)
print("Takken full-pack candidate validation passed.")
