#!/usr/bin/env python3
"""Select a reviewed Free Sample with an explicit v18 distribution profile."""
import argparse
import sys
from pathlib import Path

sys.dont_write_bytecode = True

from takken_concepts import (
    FREE_SAMPLE_PROFILES_PATH,
    GOLDEN_PATH,
    MASTER_PATH,
    RELEASE_CANDIDATE_ROOT,
    ROOT,
    VARIANTS_PATH,
    load_json,
    select_free_sample_with_profile,
    write_json_new,
)


parser = argparse.ArgumentParser()
parser.add_argument("--profile", default="current-gyoho-100")
parser.add_argument("--profiles", type=Path, default=FREE_SAMPLE_PROFILES_PATH)
parser.add_argument("--variants", type=Path, default=VARIANTS_PATH)
parser.add_argument("--golden", type=Path, default=GOLDEN_PATH)
parser.add_argument("--concept-master", type=Path, default=MASTER_PATH)
parser.add_argument("--output", type=Path)
arguments = parser.parse_args()


def absolute(path: Path) -> Path:
    return path if path.is_absolute() else ROOT / path


profiles = load_json(absolute(arguments.profiles))["profiles"]
profile = next(
    (value for value in profiles if value["profileID"] == arguments.profile), None
)
if profile is None:
    print(f"unknown free sample profile: {arguments.profile}")
    raise SystemExit(2)
variant_document = load_json(absolute(arguments.variants))
variants = variant_document.get("variants") or variant_document
master = load_json(absolute(arguments.concept_master))
golden = load_json(absolute(arguments.golden))
errors, selected = select_free_sample_with_profile(
    variants, master, golden, profile
)
if errors:
    for error in errors[:50]:
        print(f"ERROR: {error}")
    if len(errors) > 50:
        print(f"ERROR: ... {len(errors) - 50} additional validation error(s) omitted")
    print("No Release or ReleaseCandidate file was written.")
    raise SystemExit(1)
output = (
    absolute(arguments.output)
    if arguments.output
    else RELEASE_CANDIDATE_ROOT / f"{profile['profileID']}_candidate.json"
)
reasons = output.with_name(f"{output.stem}_selection.json")
write_json_new(output, selected)
write_json_new(
    reasons,
    {
        "schemaVersion": 1,
        "profile": profile,
        "selected": [
            {
                "conceptID": value["conceptID"],
                "variantID": value["variantID"],
                "format": value["format"],
                "category": value["category"],
                "difficulty": value["difficulty"],
                "unlockEligible": value["unlockEligible"],
            }
            for value in selected
        ],
    },
)
print(f"Generated deterministic candidate using {profile['profileID']}: {output}")
