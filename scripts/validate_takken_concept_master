#!/usr/bin/env python3
"""Validate the v17 concept master and its complete legacy-source ownership."""
import sys
from pathlib import Path

sys.dont_write_bytecode = True

from takken_concepts import (
    MASTER_PATH,
    ROOT,
    load_json,
    load_legacy_records,
    validate_concept_master,
)


if len(sys.argv) > 2:
    print("usage: ./scripts/validate_takken_concept_master [concept-master.json]")
    raise SystemExit(2)
path = Path(sys.argv[1]) if len(sys.argv) == 2 else MASTER_PATH
path = path if path.is_absolute() else ROOT / path
master = load_json(path)
known_ids = {record["question"]["id"] for record in load_legacy_records()}
errors = validate_concept_master(master, known_ids)
if errors:
    for error in errors:
        print(f"ERROR: {error}")
    raise SystemExit(1)
print(
    f"Takken concept master validation passed: "
    f"{len(master['concepts'])} concepts ({path})."
)
